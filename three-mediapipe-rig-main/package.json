{
  "name": "three-mediapipe-rig",
  "version": "0.1.41",
  "type": "module",
  "description": "Easy setup of a skeletal rig that responds to the motion tracker provided by google's mediapipe webwam feed.",
  "repository": {
    "type": "git",
    "url": "https://github.com/bandinopla/three-mediapipe-rig.git"
  },
  "module": "./dist/rigger.js",
  "types": "./dist/rigger.d.ts",
  "exports": {
    ".": {
      "import": "./dist/rigger.js",
      "types": "./dist/rigger.d.ts",
      "default": "./dist/rigger.js"
    },
    "./meshcap": {
      "import": "./dist/meshcap.js",
      "types": "./dist/meshcap.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config vite.dev.config.ts",
    "build": "vite build --config vite.lib.config.ts",
    "build:web": "vite build --config vite.dev.config.ts",
    "preview": "vite preview --config vite.dev.config.ts"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/three": "^0.183.1",
    "path": "^0.12.7",
    "typescript": "~5.7.2",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.4",
	"@tweenjs/tween.js": "^25.0.0"
  },
  "peerDependencies": {
    "@mediapipe/tasks-vision": "^0.10.32",
    "fflate": "^0.8.2",
    "three": "^0.183.1"
  },
  "license": "MIT",
  "packageManager": "pnpm@9.0.0"
}
